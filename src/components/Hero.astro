---
// Hero.astro
---

<section class="hero wrap">
  <p class="hero-eyebrow label">Personal Portfolio</p>
  <h1 class="hero-name">Deserae Mendoza</h1>
  <p class="hero-role label">Design Engineer · LA</p>
  <p class="hero-bio">
    Building thoughtful interfaces at the intersection of design and code.
    Currently exploring generative design systems.
  </p>
  <div class="hero-ctas">
    <a href="/work" class="btn btn-primary">View work →</a>
    <a href="/contact" class="btn btn-secondary">Get in touch</a>
  </div>
</section>

<style>
  .hero {
    padding-top: var(--space-5);
    padding-bottom: var(--space-5);
    max-width: 640px;
  }
  
  .hero-eyebrow {
    margin-bottom: var(--space-2);
  }
  
  .hero-eyebrow::after {
    content: "_";
    color: var(--color-accent);
    animation: blink 1.1s steps(1) infinite;
  }
  
  @keyframes blink {
    50% { opacity: 0; }
  }
  
  .hero-name {
    font-size: clamp(2.25rem, 5vw, 3.25rem);
    margin-bottom: var(--space-2);
  }
  
  .hero-role {
    margin-bottom: var(--space-3);
  }
  
  .hero-bio {
    color: var(--color-ink-soft);
    font-size: 1.05rem;
    max-width: 46ch;
    margin-bottom: var(--space-4);
  }
  
  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
  
  .btn {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    text-decoration: none;
    padding: 0.85rem 1.25rem;
    border-radius: 4px;
    transition: transform 0.15s ease, background 0.15s ease;
  }
  
  .btn-primary {
    background: var(--color-ink);
    color: var(--color-bg);
  }
  
  .btn-primary:hover {
    transform: translateY(-1px);
  }
  
  .btn-secondary {
    background: transparent;
    color: var(--color-ink);
    border: 1px solid var(--color-line);
  }
  
  .btn-secondary:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
</style>