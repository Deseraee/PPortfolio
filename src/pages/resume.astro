---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Resume | Deserae Mendoza</title>
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,600&family=Inter:opsz@14..32&family=IBM+Plex+Mono&display=swap" rel="stylesheet" />
  </head>
  <body>
    <Nav />
    <main>
      <section class="resume-page wrap">
        <div class="resume-header">
          <h1 class="resume-title">Resume</h1>
          <div class="resume-actions">
            <a href="/resume.pdf" class="btn btn-primary" download>
             Download PDF
            </a>
            <a href="/" class="btn btn-secondary">
              ← Back to Home
            </a>
          </div>
        </div>
        
        <div class="resume-content">
          <!-- Resume Embed -->
          <div class="resume-embed">
            <iframe 
              src="/resume.pdf"
              width="100%"
              height="800px"
              class="resume-iframe"
              title="Resume PDF"
            >
              <p>Your browser doesn't support PDFs. 
                <a href="/resume.pdf" download>Download the PDF instead.</a>
              </p>
            </iframe>
          </div>
          
          <!-- Fallback if PDF doesn't load -->
          <div class="resume-fallback">
            <p class="fallback-text">
              Can't view the PDF? 
              <a href="/resume.pdf" download class="fallback-link">
                Download it here →
              </a>
            </p>
          </div>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  .resume-page {
    padding-top: var(--space-4);
    padding-bottom: var(--space-5);
    max-width: 1000px;
  }
  
  .resume-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
    border-bottom: 1px solid var(--color-line);
    padding-bottom: var(--space-2);
  }
  
  .resume-title {
    font-family: var(--font-display);
    font-size: 2.5rem;
    font-weight: 600;
    line-height: 1.1;
    margin: 0;
    color: var(--color-ink);
  }
  
  .resume-actions {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }
  
  .btn {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    text-decoration: none;
    padding: 0.75rem 1.5rem;
    border-radius: 4px;
    transition: all 0.15s ease;
    letter-spacing: 0.02em;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  
  .btn-primary {
    background: var(--color-ink);
    color: var(--color-bg);
  }
  
  .btn-primary:hover {
    transform: translateY(-2px);
    background: var(--color-accent);
  }
  
  .btn-secondary {
    background: transparent;
    color: var(--color-ink);
    border: 1px solid var(--color-line);
  }
  
  .btn-secondary:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    transform: translateY(-2px);
  }
  
  .resume-content {
    background: var(--color-bg);
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
  }
  
  .resume-embed {
    width: 100%;
    min-height: 800px;
    background: #f5f5f5;
  }
  
  .resume-iframe {
    border: none;
    width: 100%;
    height: 800px;
    display: block;
  }
  
  .resume-fallback {
    display: none;
    padding: var(--space-3);
    text-align: center;
    background: #fff3cd;
    border-top: 1px solid #ffc107;
  }
  
  .fallback-text {
    font-size: 1rem;
    color: #856404;
    margin: 0;
  }
  
  .fallback-link {
    color: var(--color-accent);
    text-decoration: none;
    font-weight: 600;
  }
  
  .fallback-link:hover {
    text-decoration: underline;
  }
  
  @media (max-width: 768px) {
    .resume-header {
      flex-direction: column;
      align-items: flex-start;
    }
    
    .resume-title {
      font-size: 2rem;
    }
    
    .resume-actions {
      width: 100%;
    }
    
    .resume-actions .btn {
      flex: 1;
      justify-content: center;
    }
    
    .resume-iframe {
      height: 500px;
    }
    
    .resume-embed {
      min-height: 500px;
    }
  }
</style>
