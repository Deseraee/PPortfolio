---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>About Me | Deserae Mendoza</title>
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,600&family=Inter:opsz@14..32&family=IBM+Plex+Mono&display=swap" rel="stylesheet" />
  </head>
  <body>
    <Nav />
    <main>
      <section class="about-page wrap">
        <div class="about-header">
          <span class="label">ABOUT ME</span>
        </div>
        
        <div class="about-grid">
          <div class="about-image">
            <div class="headshot-circle">
              <img 
                src="/deserae_ucsb_edu-a57885b4-original.jpg"
                alt="Deserae Mendoza" 
                class="headshot"
              />
            </div>
          </div>
          
          <div class="about-content">
            <h1 class="about-name">Deserae Mendoza</h1>
            <p class="about-title">SOFTWARE ENGINEERING INTERN · UC SANTA BARBARA</p>
            
            <div class="about-bio">
              <p>
                I'm a passionate software engineer building high-impact software with 
                technical integrity, creative imagination, and a user-first focus.
              </p>
              <p>
                Currently studying Comptuer Science at UC Santa Barbara, entering my thrid year. I'm constantly exploring new 
                technologies and ways to create meaningful digital experiences. I have a intserted in software developement, cryberserucity and cloud computing.
              </p>
              <p>
                When I'm not coding, you can find me the rock climbing gym, dancing salsa or batacha and hanging out with my friends and cats.
              </p>
            </div>
            
            <div class="about-actions">
              <a href="/portfolio" class="btn btn-primary">View My Work</a>
              <a href="/resume.pdf" class="btn btn-secondary">Download Resume (PDF)</a>
            </div>
          </div>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  .about-page {
    padding-top: var(--space-5);
    padding-bottom: var(--space-5);
    max-width: 880px;
  }
  
  .about-header {
    margin-bottom: var(--space-4);
    border-bottom: 1px solid var(--color-line);
    padding-bottom: var(--space-2);
  }
  
  .about-header .label {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    color: var(--color-ink-soft);
    text-transform: uppercase;
  }
  
  .about-grid {
    display: grid;
    grid-template-columns: 250px 1fr;
    gap: var(--space-4);
    align-items: start;
  }
  
  .headshot-circle {
    width: 200px;
    height: 200px;
    border-radius: 50%;
    overflow: hidden;
    border: 3px solid var(--color-line);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
  }
  
  .headshot {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 20%;
    display: block;
  }
  
  .about-name {
    font-family: var(--font-display);
    font-size: 2.5rem;
    font-weight: 600;
    line-height: 1.1;
    margin: 0 0 var(--space-1) 0;
    color: var(--color-ink);
  }
  
  .about-title {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    letter-spacing: 0.05em;
    color: var(--color-ink-soft);
    margin-bottom: var(--space-3);
    text-transform: uppercase;
  }
  
  .about-bio p {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--color-ink);
    margin-bottom: var(--space-2);
  }
  
  .about-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-3);
  }
  
  .btn {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    text-decoration: none;
    padding: 0.85rem 1.5rem;
    border-radius: 4px;
    transition: transform 0.15s ease, background 0.15s ease;
    letter-spacing: 0.02em;
  }
  
  .btn-primary {
    background: var(--color-ink);
    color: var(--color-bg);
  }
  
  .btn-primary:hover {
    transform: translateY(-2px);
    background: var(--color-accent);
  }
  
  .btn-secondary {
    background: transparent;
    color: var(--color-ink);
    border: 1px solid var(--color-line);
  }
  
  .btn-secondary:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    transform: translateY(-2px);
  }
  
  @media (max-width: 768px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: var(--space-3);
    }
    
    .about-image {
      display: flex;
      justify-content: center;
    }
    
    .headshot-circle {
      width: 160px;
      height: 160px;
    }
    
    .about-name {
      font-size: 2rem;
    }
    
    .about-actions {
      flex-direction: column;
    }
    
    .about-actions .btn {
      text-align: center;
    }
  }
</style>
